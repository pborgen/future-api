{
    "swagger": "2.0",
    "info": {
        "description": "HTTP/JSON API for scheduling 30-minute trainer appointments. All times are RFC3339; business hours are evaluated in America/Los_Angeles (M-F 8am-5pm).",
        "title": "Future Appointment API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/appointments": {
            "post": {
                "description": "Creates a 30-minute appointment for the given trainer and user. The slot must start on :00 or :30, fall within M-F 8am-5pm Pacific, and not overlap an existing booking for the trainer.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "appointments"
                ],
                "summary": "Book a new appointment",
                "parameters": [
                    {
                        "description": "Appointment to create",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/appointment.CreateRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/appointment.Appointment"
                        }
                    },
                    "400": {
                        "description": "malformed request",
                        "schema": {
                            "$ref": "#/definitions/httputil.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "trainer already booked at that time",
                        "schema": {
                            "$ref": "#/definitions/httputil.ErrorResponse"
                        }
                    },
                    "422": {
                        "description": "outside business hours, wrong duration, or not on :00/:30",
                        "schema": {
                            "$ref": "#/definitions/httputil.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/httputil.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/trainers/{trainer_id}/appointments": {
            "get": {
                "description": "Returns every appointment booked with the given trainer, ordered by start time.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "appointments"
                ],
                "summary": "List a trainer's scheduled appointments",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Trainer ID",
                        "name": "trainer_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/appointment.Appointment"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/httputil.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/httputil.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/trainers/{trainer_id}/availability": {
            "get": {
                "description": "Returns every bookable 30-minute slot for the trainer between starts_at and ends_at. Slots that overlap an existing booking are excluded. Times must be RFC3339.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "appointments"
                ],
                "summary": "List available appointment slots for a trainer",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Trainer ID",
                        "name": "trainer_id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "example": "2026-04-06T08:00:00-07:00",
                        "description": "Window start (RFC3339)",
                        "name": "starts_at",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "example": "2026-04-06T17:00:00-07:00",
                        "description": "Window end (RFC3339)",
                        "name": "ends_at",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/appointment.Slot"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/httputil.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/httputil.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "appointment.Appointment": {
            "type": "object",
            "properties": {
                "ends_at": {
                    "type": "string",
                    "example": "2026-04-06T09:30:00-07:00"
                },
                "id": {
                    "type": "integer",
                    "example": 42
                },
                "starts_at": {
                    "type": "string",
                    "example": "2026-04-06T09:00:00-07:00"
                },
                "trainer_id": {
                    "type": "integer",
                    "example": 1
                },
                "user_id": {
                    "type": "integer",
                    "example": 2
                }
            }
        },
        "appointment.CreateRequest": {
            "type": "object",
            "properties": {
                "ends_at": {
                    "type": "string",
                    "example": "2026-04-06T09:30:00-07:00"
                },
                "starts_at": {
                    "type": "string",
                    "example": "2026-04-06T09:00:00-07:00"
                },
                "trainer_id": {
                    "type": "integer",
                    "example": 1
                },
                "user_id": {
                    "type": "integer",
                    "example": 2
                }
            }
        },
        "appointment.Slot": {
            "type": "object",
            "properties": {
                "ends_at": {
                    "type": "string",
                    "example": "2026-04-06T09:30:00-07:00"
                },
                "starts_at": {
                    "type": "string",
                    "example": "2026-04-06T09:00:00-07:00"
                }
            }
        },
        "httputil.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "invalid trainer_id"
                }
            }
        }
    }
}