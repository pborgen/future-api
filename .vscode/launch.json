{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run API server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/server",
      "cwd": "${workspaceFolder}",
      "env": {
        "DATABASE_URL": "postgres://future:future@localhost:5432/future?sslmode=disable",
        "HTTP_ADDR": ":8080",
        "MIGRATIONS_DIR": "migrations",
        "SEED_FILE": "appointments.json",
        "GIN_MODE": "debug"
      }
    },
    {
      "name": "Debug API server",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/server",
      "cwd": "${workspaceFolder}",
      "env": {
        "DATABASE_URL": "postgres://future:future@localhost:5432/future?sslmode=disable",
        "HTTP_ADDR": ":8080",
        "MIGRATIONS_DIR": "migrations",
        "SEED_FILE": "appointments.json",
        "GIN_MODE": "debug"
      }
    },
    {
      "name": "Test: current package",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Test: integration (appointment)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/internal/appointment",
      "cwd": "${workspaceFolder}",
      "args": ["-test.run", "TestIntegration", "-test.v"],
      "env": {
        "TEST_DATABASE_URL": "postgres://future:future@localhost:5432/future?sslmode=disable"
      }
    }
  ]
}
